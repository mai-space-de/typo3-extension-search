plugin.tx_maisearch {
    view {
        templateRootPath = EXT:mai_search/Resources/Private/Templates/
        partialRootPath = EXT:mai_search/Resources/Private/Partials/
        layoutRootPath = EXT:mai_search/Resources/Private/Layouts/
    }

    settings {
        solr {
            # Host overridden by TYPO3_SOLR_HOST in DDEV (solr) and production env.
            host = localhost
            port = 8983
            # Must not contain "/solr/" — Solarium adds its own context segment.
            path = /
            scheme = http

            core = core_en

            coreMapping {
                en = core_en
                de = core_de
                uk = core_uk
                ar = core_ar
            }
        }

        resultsPerPage = 20

        # RAG (Retrieval-Augmented Generation)
        # When enabled, top search results are synthesised into an AI-generated answer card.
        # Requires: Solr DenseVectorField schema, OpenAI API key in mai_translate.
        ragEnabled = 0
    }
}
